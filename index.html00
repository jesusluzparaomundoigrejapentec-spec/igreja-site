}

.hero-content {
    position: relative;
    z-index: 2;
    padding: 20px;
}

.hero h1 {
    font-size: 42px;
    text-shadow: 0 0 25px #00aaff;
}

.hero p {
    font-size: 20px;
}

.btn {
    margin-top: 25px;
    padding: 15px 35px;
    background: #00aaff;
    color: white;
    text-decoration: none;
    font-weight: bold;
    border-radius: 30px;
    box-shadow: 0 0 20px #00aaff;
    display: inline-block;
}

section {
    padding: 60px 20px;
    text-align: center;
    background: #000;
}

.box {
    max-width: 900px;
    margin: auto;
    padding: 30px;
    background: rgba(0,0,0,0.9);
    border-radius: 15px;
    box-shadow: 0 0 25px #00aaff;
}

h2 {
    color: #00aaff;
    margin-bottom: 20px;
}

footer {
